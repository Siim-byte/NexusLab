@using Nexus.Models.Brands

@model Nexus.Models.Brands.BrandsCreateViewModel

<div>
    <form method="post" enctype="multipart/form-data">
        <input asp-for="Id" type="hidden" />

        <div class="form-group row">
            <label asp-for="Name" class="col-sm-2 col-form-label"></label>
            <div class="col-sm-10">
                <input asp-for="Name" class="form-control" />
            </div>
        </div>
        <div class="form-group row">
            <label asp-for="Slogan" class="col-sm-2 col-form-label"></label>
            <div class="col-sm-10">
                <input asp-for="Slogan" class="form-control" />
            </div>
        </div>
        <div class="form-group row mb-3">
            <label asp-for="LogoFile" class="col-sm-2 col-form-label">Brändi logo</label>
            <div class="col-sm-10">
                @* Lisatud id="logo-input" ja eemaldatud onchange *@
                <input asp-for="LogoFile" type="file" id="logo-input" class="form-control" accept="image/*" />
            </div>
        </div>
        <div class="form-group row mb-3">
            <label class="col-sm-2 col-form-label">Logo eelvaade:</label>
            <div class="col-sm-10">
                <img id="preview" src="#" alt="Logo eelvaade"
                     style="max-width: 200px; max-height: 200px; display: none; border: 1px solid white; padding: 5px; border-radius: 4px;" />
            </div>
        </div>
        <input asp-action="Create" asp-controller="Brands" type="submit" class="btn btn-primary" value="Create" />
        <a asp-action="Index" asp-controller="Brands" class="btn btn-success">Back</a>
    </form>
</div>

@section Scripts {
    <script>
        document.getElementById('logo-input').addEventListener('change', function () {
            if (this.files && this.files[0]) {
                var previewImg = document.getElementById('preview');
                previewImg.src = URL.createObjectURL(this.files[0]);
                previewImg.style.display = 'block';
            }
        });
    </script>
}
