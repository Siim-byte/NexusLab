@using Nexus.Core.Domain
@using Nexus.Models.Products

@model Nexus.Models.Products.ProductsCreateViewModel

<div>
    <form method="post" enctype="multipart/form-data">
        <input asp-for="ProductId" type="hidden" />
        
        <div class="form-group row">
            <label asp-for="Name" class="col-sm-2 col-form-label"></label>
            <div class="col-sm-10">
                <input asp-for="Name" class="form-control" />
            </div>
        </div>
        <div class="form-group row">
            <label asp-for="Price" class="col-sm-2 col-form-label"></label>
            <div class="col-sm-10">
                <input asp-for="Price" class="form-control" />
            </div>
        </div>
        <div class="form-group row">
            <label asp-for="Quality" class="col-sm-2 col-form-label"></label>
            <div class="col-sm-10">
                <input asp-for="Quality" class="form-control" />
            </div>
        </div>
        <div class="form-group row">
            <label asp-for="Stock" class="col-sm-2 col-form-label"></label>
            <div class="col-sm-10">
                <input asp-for="Stock" class="form-control" />
            </div>
        </div>
        <div class="form-group row">
            <label asp-for="Description" class="col-sm-2 col-form-label"></label>
            <div class="col-sm-10">
                <input asp-for="Description" class="form-control" />
            </div>
        </div>
        <input asp-action="Create" asp-controller="Products" type="submit" class="btn btn-primary" value="Create" />
        <a asp-action="Index" asp-controller="Products" class="btn btn-success">Back</a>
    </form>
</div>