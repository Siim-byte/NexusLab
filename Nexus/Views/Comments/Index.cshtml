@model IEnumerable<Nexus.Models.Comments.CommentsIndexViewModel>

@{
    int rowNumber = 1;
}
<div>
    <a asp-action="Create" asp-controller="Comments" asp-route-productId="@Context.Request.RouteValues["id"]" type="Submit" class="btn btn-primary">Add Comment</a>
</div>
<div class="h1">
    Kommentaar
</div>
<form method="get">
    <table class="table table-hover">
        <thead>
            <tr>
                <th scope="col">Nimi</th>
                <th scope="col">Kuupäev</th>
                <th scope="col">Komment</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var comment in Model)
            {
                <tr>

                    <td>@comment.AuthorName</td>
                    <td>@comment.EntryCreatedAt</td>
                    <td>@comment.Content</td>
                    <td>
                        <a asp-action="Delete" asp-controller="Comments" asp-route-id="@comment.CommentId" class="btn btn-danger">Kustuta</a>
                        <a asp-action="Update" asp-controller="Comments" asp-route-id="@comment.CommentId" class="btn btn-danger">Muuda</a>

                    </td>
                </tr>
                rowNumber += 1;
            }
        </tbody>
    </table>
</form>