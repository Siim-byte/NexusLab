@model Nexus.Models.Comments.CommentsDeleteViewModel

<h1>Kustuta Kommentaar</h1>

<div>
    <h4>Kommentaar</h4>
    <hr />
    <dl class="row">
        <div class="form-group row">
            <label asp-for="Content" class="col-sm-2 col-form-label"></label>
            @Html.DisplayFor(model => model.Content)
        </div>
    </dl>

    <hr />
    <form asp-action="DeleteConfirmed" method="post">
        <input type="hidden" asp-for="ProductId" />
        <input type="hidden" asp-for="CommentId" />
        <input type="submit" value="Remove" class="btn btn-danger" />
        <a asp-action="Index" asp-controller="Comments" class="btn btn-danger">Tagasi</a>
    </form>
</div>