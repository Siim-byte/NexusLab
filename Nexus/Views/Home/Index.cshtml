@model IEnumerable<Nexus.Models.News.NewsIndexViewModel>
@{
    ViewData["Title"] = "Home Page";
}

<h2>Viimased uudised</h2>

@foreach (var item in Model)
{
    <div class="card mb-3">

        <div class="card-body">

            <h5>@item.Title</h5>

            <p>@item.Content</p>

            <small>@item.CreatedAt</small>
            <form asp-action="Like"
                  asp-controller="News"
                  asp-route-id="@item.NewsId"
                  method="post"
                  style="display:inline;">

                <button type="submit"
                        class="btn @(item.Likes > 0 ? "btn-danger" : "btn-outline-secondary")">

                    ❤️ (@item.Likes)

                </button>

            </form>
            

        </div>

    </div>
}