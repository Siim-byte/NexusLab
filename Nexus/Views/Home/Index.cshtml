@model IEnumerable<Nexus.Models.News.NewsIndexViewModel>
@{
    ViewData["Title"] = "Home Page";
}

<h2>Viimased uudised</h2>

@foreach (var item in Model)
{
    <div class="card mb-3">

        <div class="card-body">

            <h5>@item.Title</h5>

            <p>@item.Content</p>

            <small>@item.CreatedAt</small>

        </div>

    </div>
}